{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["main:app", "--reload", "--port", "8000", "--app-dir", "backend"],
