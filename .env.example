# ============================================================
# LaunchWise AI — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER put real secrets in this file.

# ── Google AI Studio (Gemini) ────────────────────────────────
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Google Cloud Project ─────────────────────────────────────
PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_PROJECT=your-gcp-project-name

# Optional: path to a GCP service-account JSON key, or omit entirely if you've
# run `gcloud auth application-default login`. Enables Firestore, BigQuery,
# and Cloud Storage. Without it, all three gracefully fall back to local
# storage/aggregation — the app runs fully functional either way.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Firestore ────────────────────────────────────────────────
FIRESTORE_DATABASE=your-firestore-database-id

# ── Google Maps ──────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# ── Cloud Storage ────────────────────────────────────────────
STORAGE_BUCKET=your-gcs-bucket-name

# ── Server ───────────────────────────────────────────────────
# Only honored when starting the backend via `python main.py` directly.
# Has no effect if you launch with `uvicorn main:app --port X` — the CLI
# flag wins in that case.
PORT=8000
HOST=0.0.0.0
